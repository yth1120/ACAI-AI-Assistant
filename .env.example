# 环境变量配置文件
# 请复制此文件为 .env.local 并填入你的实际配置

# 应用配置
VITE_APP_TITLE=ACAI - 私人AI助手
VITE_APP_VERSION=2.0.0

# 开发环境配置
VITE_DEV_SERVER_PORT=5173
VITE_DEV_SERVER_HOST=localhost

# API 配置（可选，也可在应用设置中配置）
# VITE_DEFAULT_API_PROVIDER=deepseek
# VITE_DEFAULT_API_KEY=your-api-key-here

# 功能开关
VITE_ENABLE_DEV_TOOLS=true
VITE_ENABLE_ERROR_REPORTING=false
VITE_ENABLE_ANALYTICS=false

# 性能配置
VITE_ENABLE_LAZY_LOADING=true
VITE_ENABLE_CODE_SPLITTING=true

# 日志级别 (debug, info, warn, error)
VITE_LOG_LEVEL=info

# Electron 配置
VITE_ELECTRON_WINDOW_WIDTH=1400
VITE_ELECTRON_WINDOW_HEIGHT=900
VITE_ELECTRON_MIN_WIDTH=1200
VITE_ELECTRON_MIN_HEIGHT=800
